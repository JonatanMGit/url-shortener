# Keep false for production compose runs; set true only for local debugging.
FLASK_DEBUG=false
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Optional Redis cache settings (keep disabled for default local/test flows)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300
REDIS_CACHE_KEY_PREFIX=url-shortener

# Observability controls
LOG_LEVEL=INFO
LOG_FILE_PATH=

# Grafana admin credentials for docker-compose.production.yml
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
